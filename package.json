{
  "name": "sales-automation-crm",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev:client\"",
    "dev:client": "wait-on tcp:localhost:3001 && npm run dev --workspace=client",
    "build": "npm run build --workspace=server && npm run build --workspace=client",
    "seed": "npm run seed --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "wait-on": "^9.0.10"
  },
  "overrides": {
    "@types/express": "^4.17.21",
    "@types/express-serve-static-core": "^4.19.6"
  }
}
